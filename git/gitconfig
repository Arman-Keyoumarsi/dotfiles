[color]
    branch = auto
    diff = auto
    status = auto
[color "branch"]
    current = yellow reverse
    local = yellow
    remote = green
[color "status"]
    added = green
    changed = red
    untracked = cyan
[user]
	name = Arman Keyoumarsi
	email = Arman-Keyoumarsi@users.noreply.github.com
[merge]
	conflictstyle = diff3
[branch]
	sort = -authordate

[alias]
   s = status
   c = !git add -A && git commit
   co = checkout
   sw = switch
   d = diff
   ds = diff --stat
   b = branch
   l = log --graph --decorate --pretty=oneline --abbrev-commit
   p = push
   pl = pull
   wip = !git add -A && git commit -m 'wip'

   # undo commit (keep changes staged)
   uc = reset --soft HEAD^
   # unstage all
   us = reset HEAD

   # tags
   nt = !sh -c 'git tag $0 -am \"$1\" && git push --tags origin'
   dt = !sh -c 'git tag -d \"$0\" && git push origin :refs/tags/$0'

   # branches
   rpo = remote prune origin
   dmb = !git branch --merged | grep -Ev \"(^\\*|master|main|dev)\" | xargs git branch -d
[core]
	excludesfile = ~/.gitignore
    editor       = "vim"
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
