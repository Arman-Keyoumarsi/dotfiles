#!/usr/bin/env zsh

# ~/.zprofile: login shell setup (macOS-specific, maps to bash_profile)

if [[ "$OSTYPE" == darwin* ]]; then
	eval "$(/opt/homebrew/bin/brew shellenv)"
	export CLICOLOR=1
	export LSCOLORS=GxFxCxDxBxegedabagaced

	# Python (Homebrew) - auto-detect latest version
	_brew_python=("${(@On)$(ls -d /opt/homebrew/opt/python@3.*/libexec/bin 2>/dev/null)}")
	if (( ${#_brew_python} )); then
		export PATH="${_brew_python[1]}:$PATH"
		_pyver=${${_brew_python[1]:h:h:t}#python@}
		export CLOUDSDK_PYTHON="/opt/homebrew/bin/python${_pyver}"
		unset _pyver
	fi
	unset _brew_python

	# Google Cloud SDK
	if [[ -f "$HOME/Downloads/google-cloud-sdk/path.zsh.inc" ]]; then
		source "$HOME/Downloads/google-cloud-sdk/path.zsh.inc"
	fi
	if [[ -f "$HOME/Downloads/google-cloud-sdk/completion.zsh.inc" ]]; then
		source "$HOME/Downloads/google-cloud-sdk/completion.zsh.inc"
	fi

	# LM Studio CLI
	if [[ -d "$HOME/.lmstudio/bin" ]]; then
		export PATH="$PATH:$HOME/.lmstudio/bin"
	fi
fi
