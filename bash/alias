#!/usr/bin/env bash

# --- Functions ---

kp() {
  local pid
  pid=$(ps -ax | sed 1d | fzf ${FZF_DEFAULT_OPTS} -m --header='[kill:process]' | awk '{print $2}')
  if [ -n "$pid" ]; then
    echo "$pid" | xargs kill -"${1:-9}"
    kp
  fi
}

f() {
	fzf --preview '[[ $(file --mime {}) =~ binary ]] && echo {} is a binary file || (bat {} || cat {}) 2> /dev/null | head -500'
}

zd() {
	cd "$(find "$1" -type d | f)" || return
}

fixssh() {
  for key in SSH_AUTH_SOCK SSH_CONNECTION SSH_CLIENT; do
    if tmux show-environment 2>/dev/null | grep "^${key}" >/dev/null; then
      value=$(tmux show-environment | grep "^${key}" | sed -e "s/^[A-Z_]*=//")
      export "${key}=${value}"
    fi
  done
}

myip() {
	dig +short myip.opendns.com @resolver1.opendns.com
}

qfind() { find . -name "$1"; }

current-version() {
	git tag -l 'v*' | sed -E 's/^v//g' | sort -g | tail -n 1
}

current-semver() {
	git tag -l | grep -E '[0-9]+\.[0-9]+\.[0-9]+' | sort -g | tail -n 1
}

# --- Bash ---

alias restart='sudo reboot'
alias shutdown='sudo halt'
alias apt-get='sudo apt-get'
alias root='sudo su -'
alias sp='source ~/.bash_profile'
alias nerd='vim +NERDTree'

alias ..='cd ../'
alias ...='cd ../../'
alias .3='cd ../../../'
alias .4='cd ../../../../'
alias .5='cd ../../../../../'
alias .6='cd ../../../../../../'

alias cp='cp -i'
alias mv='mv -i'
alias ll='ls -FGlAhp'
alias less='less -FRXc'
alias path='echo -e ${PATH//:/\\n}'
alias c="clear"
alias rmr='rm -r'
alias lal='ls -alh'
alias untar='tar xvfz'

# --- Git ---

alias g="git"
alias gpr="gh pr create"
alias gpro="gh pr create --web"
alias prco='gh pr list | fzf | grep -oE "[0-9]+" | head -1 | xargs gh pr checkout'

# --- Docker / K8s ---

alias d="docker"
alias k='kubectl'

# --- Tools ---

alias t=terraform
alias yolo='claude --dangerously-skip-permissions'
alias lt='tree -L 1 -C'
alias tfl='tail -Fn30 log/*.log'
# Wrap ssh to reset mouse tracking on exit (prevents garbled input in Ghostty after tmux/vim)
unalias ssh 2>/dev/null
ssh() {
    TERM=xterm-256color command ssh "$@"
    printf '\e[?1000l\e[?1002l\e[?1003l\e[?1006l'
}
alias reshell="exec -l $SHELL"

# Python - auto-detect python3
if command -v python3 &>/dev/null; then
    alias python='python3'
    alias py='python3'
    alias pip='pip3'
fi

# --- Curl ---

alias curlb='curl -s'
alias curls='curl -svo /dev/null'
alias curl-ttfb='curls -w "Connect: %{time_connect} TTFB: %{time_starttransfer} Total time: %{time_total} \n"'

# --- Platform-specific ---

if [[ "$OSTYPE" == "linux"* ]]; then
	alias ls='ls -p --color=auto'
	# xsel as pbcopy/pbpaste on Linux
	if command -v xsel &>/dev/null; then
		alias pbcopy='xsel --clipboard --input'
		alias pbpaste='xsel --clipboard --output'
	fi
elif [[ "$OSTYPE" == "darwin"* ]]; then
	alias ls='ls -Gp'
fi

alias copy="tr -d '\n' | pbcopy"

# --- SSH ---

alias sshhosts="grep -w -i -E 'Host|HostName' ~/.ssh/config | sed 's/Host //' | sed 's/HostName //'"

